/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     TreeNode *left;
 *     TreeNode *right;
 *     TreeNode() : val(0), left(nullptr), right(nullptr) {}
 *     TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
 *     TreeNode(int x, TreeNode *left, TreeNode *right) : val(x), left(left), right(right) {}
 * };
 */
class Solution {
public:
    vector<int>inorder;
    void sortroot(TreeNode* root)
    {
        if(root==NULL)
        {
            return;
        }
        sortroot(root->left);
        inorder.push_back(root->val);
        sortroot(root->right);
    }
    TreeNode* divnconq(int l,int r)
    {
        if(l>r)
        {
            return NULL;
        }
        int mid=l+(r-l)/2;
        TreeNode* le=divnconq(l,mid-1);
        TreeNode* ri=divnconq(mid+1,r);
        return new TreeNode(inorder[mid],le,ri);
    }
    TreeNode* balanceBST(TreeNode* root) {
        sortroot(root);
        int l=0;
        int r=inorder.size();
        return divnconq(l,r-1);
    }
};
