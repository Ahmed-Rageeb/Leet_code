class Solution {
public:
    vector<int> separateDigits(vector<int>& nums) {
        vector<int>ans;
        for(int i=0;i<nums.size();i++)
        {
            string temp=to_string(nums[i]);
            for(int j=0;j<temp.length();j++)
            {
                
                int l=temp[j]-'0';
                ans.push_back(l);
            }
        }
        return ans;
    }
};
