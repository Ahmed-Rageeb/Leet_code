class Solution {
public:
    int minElement(vector<int>& nums) {
        int min=INT_MAX;
        for(int i=0;i<nums.size();i++)
        {
            string a=to_string(nums[i]);
            int sum=0;
            for(int j=0;j<a.length();j++)
            {
                sum+=a[j]-'0';
            }
            if(sum<min)
            {
                min=sum;
            }
        }
        return min;
    }
};
