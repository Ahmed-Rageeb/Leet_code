class Solution {
public:
    int earliestFinishTime(vector<int>& landStartTime, vector<int>& landDuration, vector<int>& waterStartTime, vector<int>& waterDuration) {
        int min=INT_MAX;
        for(int i=0;i<landStartTime.size();i++)
        {
            for(int j=0;j<waterStartTime.size();j++)
            {
                int landduration=landStartTime[i]+landDuration[i];
                int waterduration=max(landduration,waterStartTime[j])+waterDuration[j];
                if(min>waterduration)
                {
                    min=waterduration;
                }
                waterduration=waterStartTime[j]+waterDuration[j];
                landduration=max(waterduration,landStartTime[i])+landDuration[i];
                if(min>landduration)
                {
                    min=landduration;
                }
            }
        }
        return min;
    }
};
